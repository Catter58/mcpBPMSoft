# ==============================================================
# mcp-bpmsoft-odata — пример конфигурации
# Скопируйте в .env и заполните под свой инстанс BPMSoft.
# Не коммитьте .env с реальными секретами в репозиторий.
# ==============================================================

# --------------------------------------------------------------
# Required: подключение к BPMSoft
# Если хотя бы одна из трёх переменных не задана, сервер
# стартует в интерактивном режиме и ждёт вызова bpm_init.
# --------------------------------------------------------------

# Базовый URL инстанса BPMSoft (без trailing slash)
BPMSOFT_URL=https://crm.example.com

# Имя пользователя для AuthService.svc
BPMSOFT_USERNAME=your_username

# Пароль пользователя
BPMSOFT_PASSWORD=your_password

# --------------------------------------------------------------
# Optional: версия OData и платформа
# --------------------------------------------------------------

# Версия OData: 3 или 4 (default: 4).
# OData 3 поддерживается только при BPMSOFT_PLATFORM=netframework.
BPMSOFT_ODATA_VERSION=4

# Платформа: net8 или netframework (default: net8).
# Влияет на формирование базового URL:
#   net4 + net8         → {url}/odata
#   net4 + netframework → {url}/0/odata
#   net3 + netframework → {url}/0/ServiceModel/EntityDataService.svc
BPMSOFT_PLATFORM=net8

# --------------------------------------------------------------
# Optional: лимиты и таймауты
# --------------------------------------------------------------

# Размер страницы при автопагинации (default: 5000)
BPMSOFT_PAGE_SIZE=5000

# Максимум операций в одном $batch (default: 100; лимит BPMSoft 1.8)
BPMSOFT_MAX_BATCH_SIZE=100

# TTL кэша lookup-резолвинга в секундах (default: 300)
BPMSOFT_LOOKUP_CACHE_TTL=300

# Таймаут HTTP-запроса в миллисекундах (default: 30000)
BPMSOFT_REQUEST_TIMEOUT=30000

# Максимальный размер файла в байтах (default: 10485760 = 10 MB)
BPMSOFT_MAX_FILE_SIZE=10485760

# --------------------------------------------------------------
# Optional: отладка
# --------------------------------------------------------------

# Уровень логов:
#   1     — debug (URL, метод, статус)
#   trace — полный дамп HTTP-обмена (НЕ для production)
# Закомментируйте для штатного режима.
# BPMSOFT_DEBUG=1
